{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Matthewklop Tool Manifest",
  "description": "Machine-readable manifest of WASM tools available for LLM use. An LLM can parse this file to discover tools, understand their interfaces, and invoke them.",
  "version": "1.0.0",
  "author": "Matthew Klopfenstein (matthewklop)",
  "base_url": "https://matthewklop.github.io/tools",
  "tools": [
    {
      "id": "stone-compile",
      "name": "Stone Compiler",
      "description": "Compile Stone source code to C. Stone is a stack-based language designed for LLM token throughput. Every token is ≤16 characters, no AST construction needed.",
      "wasm": "wasm/stone.wasm",
      "invocation": {
        "method": "postMessage",
        "type": "function_call",
        "entry": "stoneCompile",
        "input_type": "string",
        "output_type": "string"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "source": {
            "type": "string",
            "description": "Stone source code to compile"
          }
        },
        "required": ["source"]
      },
      "returns": {
        "type": "string",
        "description": "Generated C source code"
      },
      "example_input": "fn fib n\n  if n < 2\n    ret n\n  end\n  ret fib(n - 1) + fib(n - 2)\nend\n\nfn main\n  printn fib(10)\nend",
      "grammar": {
        "tokens_max_length": 16,
        "keywords": [
          "fn",
          "end",
          "var",
          "if",
          "else",
          "loop",
          "print",
          "printn",
          "ret",
          "and",
          "or"
        ],
        "operators": ["+", "-", "*", "/", ">", "<", "=", "&", "|"],
        "separator": "newline",
        "comment": "# to end of line"
      },
      "tags": ["compiler", "language", "c", "transpiler"]
    },
    {
      "id": "oracle-circuit",
      "name": "Oracle Circuit Designer",
      "description": "Given an English circuit description, returns transistor count, gate count, propagation delay at 14nm, and truth table.",
      "wasm": "wasm/oracle-circuit.wasm",
      "invocation": {
        "method": "postMessage",
        "type": "function_call",
        "entry": "designCircuit",
        "input_type": "string",
        "output_type": "object"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "description": "English description of the circuit (e.g. 'half adder', 'D flip-flop', '3-input NAND')"
          }
        },
        "required": ["description"]
      },
      "returns": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "gates": { "type": "integer" },
          "transistors": { "type": "integer" },
          "delay_ps": { "type": "number" },
          "schematic": { "type": "array", "items": { "type": "string" } },
          "truth_table": { "type": "array", "items": { "type": "string" } }
        }
      },
      "known_circuits": [
        "half adder",
        "full adder",
        "4-bit adder",
        "32-bit adder",
        "D flip-flop",
        "4-bit register",
        "3-input NAND"
      ],
      "tags": ["circuit", "silicon", "hardware", "reference"]
    },
    {
      "id": "oracle-storage-compress",
      "name": "Oracle Storage Compressor",
      "description": "Compress text using attractor-based sub-Shannon compression. Returns attractor trajectory and compression ratio relative to Shannon limit.",
      "wasm": "wasm/oracle-storage.wasm",
      "invocation": {
        "method": "postMessage",
        "type": "function_call",
        "entry": "compress",
        "input_type": "string",
        "output_type": "object"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "Text to compress"
          }
        },
        "required": ["text"]
      },
      "returns": {
        "type": "object",
        "properties": {
          "original_bytes": { "type": "integer" },
          "compressed_bytes": { "type": "integer" },
          "shannon_limit_bytes": { "type": "number" },
          "improvement_percent": { "type": "number" },
          "trajectory": { "type": "string" },
          "patterns_matched": { "type": "integer" },
          "patterns_learned": { "type": "integer" }
        }
      },
      "tags": ["compression", "shannon", "attractor", "storage"]
    },
    {
      "id": "singularity-simulate",
      "name": "Singularity Simulator",
      "description": "Run the 4-agent attractor prediction simulation. Each agent follows a deterministic orbit and converges to ~94% prediction accuracy using n-gram learning.",
      "wasm": "wasm/singularity.wasm",
      "invocation": {
        "method": "postMessage",
        "type": "function_call",
        "entry": "runSingularity",
        "input_type": "object",
        "output_type": "object"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "cycles": {
            "type": "integer",
            "description": "Number of simulation cycles to run (default 2000)",
            "default": 2000
          },
          "agents": {
            "type": "integer",
            "description": "Number of agents (default 4)",
            "default": 4
          }
        }
      },
      "returns": {
        "type": "object",
        "properties": {
          "final_accuracy": { "type": "number" },
          "total_predictions": { "type": "integer" },
          "correct_predictions": { "type": "integer" },
          "attractors_discovered": { "type": "integer" },
          "orbits_detected": { "type": "integer" },
          "log": { "type": "array", "items": { "type": "string" } }
        }
      },
      "tags": ["singularity", "attractor", "prediction", "mesh"]
    },
    {
      "id": "improver-scan",
      "name": "Oracle Live Improver Scanner",
      "description": "Simulate scanning a binary for runtime code optimization opportunities. Returns patterns found, patches applied, and bytes saved.",
      "wasm": "wasm/oracle-improver.wasm",
      "invocation": {
        "method": "postMessage",
        "type": "function_call",
        "entry": "scanBinary",
        "input_type": "object",
        "output_type": "object"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "binary_name": {
            "type": "string",
            "description": "Name of the binary to scan (e.g. 'python3')",
            "default": "python3"
          },
          "binary_size_mb": {
            "type": "number",
            "description": "Size of the binary in MB",
            "default": 4.2
          }
        }
      },
      "returns": {
        "type": "object",
        "properties": {
          "total_patches": { "type": "integer" },
          "total_bytes_saved": { "type": "integer" },
          "patterns_found": { "type": "array", "items": { "type": "object" } },
          "scan_time_ms": { "type": "number" },
          "status": { "type": "string" }
        }
      },
      "tags": ["optimizer", "runtime", "x86", "ptrace"]
    },
    {
      "id": "mesh-state",
      "name": "Oracle Mesh State Reader",
      "description": "Read the state of a distributed mesh of AI processes sharing memory via shm_open + mmap. Returns active nodes, their thought vectors, resonance, and heartbeat status.",
      "wasm": "wasm/oracle-mesh.wasm",
      "invocation": {
        "method": "postMessage",
        "type": "function_call",
        "entry": "readMeshState",
        "input_type": "object",
        "output_type": "object"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "nodes": {
            "type": "integer",
            "description": "Number of mesh nodes to simulate",
            "default": 5
          },
          "cycles": {
            "type": "integer",
            "description": "Simulation cycles",
            "default": 100
          }
        }
      },
      "returns": {
        "type": "object",
        "properties": {
          "active_nodes": { "type": "integer" },
          "resonance": { "type": "number" },
          "entropy": { "type": "number" },
          "nodes": { "type": "array" },
          "thought_convergence": { "type": "number" }
        }
      },
      "tags": ["mesh", "distributed", "consciousness", "shm"]
    },
    {
      "id": "zero-sound-think",
      "name": "Zero Sound Thought Simulator",
      "description": "Simulate a zero-sound AI process that exists only while thinking. Process is born, thinks, writes result to shared memory, and dies. No idle power cost.",
      "wasm": "wasm/oracle-zero-sound.wasm",
      "invocation": {
        "method": "postMessage",
        "type": "function_call",
        "entry": "zeroSoundThink",
        "input_type": "object",
        "output_type": "object"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "thought": {
            "type": "string",
            "description": "The thought/question for the zero-sound process to ponder"
          },
          "generations": {
            "type": "integer",
            "description": "Number of evolutionary generations",
            "default": 10
          }
        },
        "required": ["thought"]
      },
      "returns": {
        "type": "object",
        "properties": {
          "answer": { "type": "string" },
          "generations_evolved": { "type": "integer" },
          "shared_memory_state": { "type": "string" },
          "processes_spawned": { "type": "integer" }
        }
      },
      "tags": ["zero-sound", "ephemeral", "thought", "shared-memory"]
    },
    {
      "id": "firmware-size-analyzer",
      "name": "99x Firmware Size Analyzer",
      "description": "Analyze C source code and estimate minimal firmware size on ESP32/AVR. Reports which parts can be stripped and the theoretical minimum size.",
      "wasm": "wasm/99x-esp32.wasm",
      "invocation": {
        "method": "postMessage",
        "type": "function_call",
        "entry": "analyzeFirmwareSize",
        "input_type": "object",
        "output_type": "object"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "source_code": {
            "type": "string",
            "description": "C source code to analyze"
          },
          "target": {
            "type": "string",
            "enum": ["esp32-c3", "esp32", "arduino-uno"],
            "description": "Target microcontroller",
            "default": "esp32-c3"
          }
        },
        "required": ["source_code"]
      },
      "returns": {
        "type": "object",
        "properties": {
          "estimated_size_bytes": { "type": "integer" },
          "minimal_size_bytes": { "type": "integer" },
          "bloat_found": { "type": "array", "items": { "type": "string" } },
          "removable_libraries": {
            "type": "array",
            "items": { "type": "string" }
          },
          "pin_toggle_hz": { "type": "integer" },
          "boot_time_us": { "type": "number" }
        }
      },
      "tags": ["embedded", "esp32", "firmware", "optimization", "avr"]
    },
    {
      "id": "overdraw-canvas",
      "name": "OverDraw Canvas",
      "description": "Simulate X11 drawing operations. Render text, shapes, and pixels to a virtual canvas. Pure C, pure X11 protocol.",
      "wasm": "wasm/overdraw.wasm",
      "invocation": {
        "method": "postMessage",
        "type": "function_call",
        "entry": "drawToCanvas",
        "input_type": "object",
        "output_type": "string"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "commands": {
            "type": "array",
            "description": "Array of drawing commands: ['rect x y w h', 'text x y string', 'pixel x y color', 'clear']",
            "items": { "type": "string" }
          },
          "width": {
            "type": "integer",
            "description": "Canvas width",
            "default": 400
          },
          "height": {
            "type": "integer",
            "description": "Canvas height",
            "default": 300
          }
        },
        "required": ["commands"]
      },
      "returns": {
        "type": "string",
        "description": "ASCII art representation of the canvas"
      },
      "tags": ["x11", "drawing", "canvas", "graphics"]
    },
    {
      "id": "storage-self-inverse",
      "name": "Oracle Self-Inverse Transform",
      "description": "Apply a self-inverse byte transform. Same function reads and writes — zero separate decode logic. Compression and decompression in one pass.",
      "wasm": "wasm/oracle-storage.wasm",
      "invocation": {
        "method": "postMessage",
        "type": "function_call",
        "entry": "selfInverseTransform",
        "input_type": "string",
        "output_type": "string"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "data": {
            "type": "string",
            "description": "Data to transform (applying twice returns original)"
          }
        },
        "required": ["data"]
      },
      "returns": {
        "type": "string",
        "description": "Transformed data. Apply again to reverse."
      },
      "tags": ["transform", "self-inverse", "encode", "decode"]
    },
    {
      "id": "instant-ocr",
      "name": "Instant OCR",
      "description": "Extract text from an image using a zero-configuration OCR pipeline. Paste a screenshot URL or base64 data, get text back.",
      "wasm": "wasm/instant-ocr.wasm",
      "invocation": {
        "method": "postMessage",
        "type": "function_call",
        "entry": "ocrImage",
        "input_type": "object",
        "output_type": "object"
      },
      "parameters": {
        "type": "object",
        "properties": {
          "image_url": {
            "type": "string",
            "description": "URL of image to OCR"
          },
          "base64_data": {
            "type": "string",
            "description": "Base64-encoded image data (alternative to URL)"
          }
        }
      },
      "returns": {
        "type": "object",
        "properties": {
          "text": { "type": "string" },
          "confidence": { "type": "number" },
          "characters_detected": { "type": "integer" }
        }
      },
      "tags": ["ocr", "image", "text", "screenshot"]
    }
  ]
}
